@ProjectManagement.Api_HostAddress = https://localhost:5001

###

### Sign up
POST {{ProjectManagement.Api_HostAddress}}/api/auth/signup
Content-Type: application/json

{
  "username": "vlad",
  "email": "vlad@example.com",
  "password": "P@ssw0rd123"
}

###

### Sign in
POST {{ProjectManagement.Api_HostAddress}}/api/auth/signin
Content-Type: application/json

{
  "email": "vlad@example.com",
  "password": "P@ssw0rd123"
}

###

### Projects - list (requires X-User-Id header)
GET {{ProjectManagement.Api_HostAddress}}/api/projects/
X-User-Id: 1

###

### Projects - create
POST {{ProjectManagement.Api_HostAddress}}/api/projects/
Content-Type: application/json
X-User-Id: 1

{
  "name": "Sample project",
  "description": "Project created from .http file",
  "dueDateUtc": "2026-12-31T12:00:00Z",
  "createdByUserId": 1,
  "participatingUserIds": []
}

###

### Projects - delete
DELETE {{ProjectManagement.Api_HostAddress}}/api/projects/1
X-User-Id: 1

###
